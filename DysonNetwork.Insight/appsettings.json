{
    "Debug": true,
    "BaseUrl": "http://localhost:5071",
    "SiteUrl": "https://solian.app",
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "App": "Host=localhost;Port=5432;Database=dyson_insight;Username=postgres;Password=postgres;Include Error Detail=True;Maximum Pool Size=20;Connection Idle Lifetime=60",
        "AgentVector": "Host=localhost;Port=5432;Database=agent_vector;Username=postgres;Password=postgres;Include Error Detail=True;Maximum Pool Size=20;Connection Idle Lifetime=60",
        "Cache": "localhost:6379"
    },
    "KnownProxies": [
        "127.0.0.1",
        "::1"
    ],
    "Etcd": {
        "Insecure": true
    },
    "Cache": {
        "Serializer": "JSON"
    },
    "Thinking": {
        "DefaultService": "deepseek-chat",
        "SystemPromptFile": "",
        "Services": {
            "deepseek-chat": {
                "Provider": "deepseek",
                "ApiMode": "chat",
                "Model": "deepseek-chat",
                "ApiKey": "sk-",
                "BillingMultiplier": 1.0,
                "PerkLevel": 0,
                "ReasoningEffort": "medium",
                "Temperature": 0.75
            },
            "deepseek-reasoner": {
                "Provider": "deepseek",
                "ApiMode": "chat",
                "Model": "deepseek-reasoner",
                "ApiKey": "sk-",
                "BillingMultiplier": 1.5,
                "PerkLevel": 1,
                "ReasoningEffort": "high",
                "Temperature": 0.7
            },
            "vision-openrouter": {
                "Provider": "openrouter",
                "Model": "anthropic/claude-3-opus",
                "ApiKey": "sk-",
                "BillingMultiplier": 2.0,
                "PerkLevel": 2
            },
            "vision-aliyun": {
                "Provider": "aliyun",
                "Model": "qwen-vl-max",
                "ApiKey": "sk-your-aliyun-api-key",
                "BillingMultiplier": 2.0,
                "PerkLevel": 2
            },
            // Custom OpenAI-compatible provider examples
            // These providers use the standard OpenAI API format but with custom endpoints
            "together-ai": {
                "Provider": "custom",
                "Model": "meta-llama/Llama-3.1-70B-Instruct-Turbo",
                "Endpoint": "https://api.together.xyz/v1",
                "ApiKey": "sk-your-together-api-key",
                "BillingMultiplier": 1.2,
                "PerkLevel": 1
            },
            "fireworks-ai": {
                "Provider": "custom",
                "Model": "accounts/fireworks/models/llama-v3p1-70b-instruct",
                "Endpoint": "https://api.fireworks.ai/inference/v1",
                "ApiKey": "sk-your-fireworks-api-key",
                "BillingMultiplier": 1.1,
                "PerkLevel": 1
            },
            "local-llm": {
                "Provider": "custom",
                "Model": "local-model",
                "Endpoint": "http://localhost:8000/v1",
                "ApiKey": "not-needed-for-local",
                "BillingMultiplier": 0.0,
                "PerkLevel": 0
            }
        }
    },
    "Embeddings": {
        "Provider": "openrouter",
        "Model": "openai/text-embedding-3-small",
        "ApiKey": "",
        "Endpoint": "https://openrouter.ai/api/v1"
    },
    "MiChan": {
        "Enabled": false,
        "GatewayUrl": "http://localhost:5070",
        "WebSocketUrl": "ws://localhost:5070/ws",
        "AccessToken": "",
        "BotAccountId": "",
        "BotAccountName": "michan", // Account username for identifying MiChan's posts
        "BotPublisherName": "michan", // Publisher name for identifying MiChan's posts (preferred over BotPublisherId)
        "BotPublisherId": "", // Deprecated: use BotPublisherName instead
        // Model configuration using the new strongly-typed format
        // ModelId: Reference to Thinking:Services key (e.g., "deepseek-chat", "vision-openrouter")
        "ThinkingModel": {
            "ModelId": "deepseek-chat",
            "Temperature": 0.75,
            "ReasoningEffort": "medium",
            "EnableFunctions": true,
            "AllowRuntimeSwitch": true
        },
        // Optional: Separate model for autonomous behavior (falls back to ThinkingModel if not set)
        "AutonomousModel": {
            "ModelId": "deepseek-reasoner",
            "Temperature": 0.7,
            "ReasoningEffort": "high",
            "EnableFunctions": true,
            "AllowRuntimeSwitch": true
        },
        // Optional: Model for scheduled tasks (falls back to ThinkingModel)
        // "ScheduledTaskModel": { "ModelId": "deepseek-chat" },
        // Optional: Model for conversation compaction (falls back to ThinkingModel)
        // "CompactionModel": { "ModelId": "deepseek-chat", "Temperature": 0.5 },
        // Optional: Model for topic generation (falls back to ThinkingModel)
        // "TopicGenerationModel": { "ModelId": "deepseek-chat" },

        // Example: Using a custom OpenAI-compatible provider inline
        // This bypasses Thinking:Services and configures the provider directly
        // "ThinkingModel": {
        //     "ModelId": "custom-together",
        //     "Provider": "custom",
        //     "BaseUrl": "https://api.together.xyz/v1",
        //     "ApiKey": "sk-your-together-api-key",
        //     "CustomModelName": "meta-llama/Llama-3.1-70B-Instruct-Turbo",
        //     "Temperature": 0.75
        // },

        // Use-case based model selection with PerkLevel requirements
        // When enabled, models are selected based on user's PerkLevel for each use case
        "UseModelSelection": false,
        "ModelSelection": {
            "DefaultModelId": "deepseek-chat",
            "AllowUserOverride": true,
            "Mappings": [
                // MiChan Chat models - users can choose based on their PerkLevel
                {
                    "UseCase": "MiChanChat",
                    "ModelId": "deepseek-chat",
                    "MinPerkLevel": 0,
                    "IsDefault": true,
                    "Priority": 100,
                    "DisplayName": "DeepSeek Chat",
                    "Description": "Fast and efficient for everyday conversations"
                },
                {
                    "UseCase": "MiChanChat",
                    "ModelId": "deepseek-reasoner",
                    "MinPerkLevel": 1,
                    "Priority": 200,
                    "DisplayName": "DeepSeek Reasoner",
                    "Description": "Advanced reasoning for complex discussions"
                },
                {
                    "UseCase": "MiChanChat",
                    "ModelId": "claude-sonnet",
                    "MinPerkLevel": 2,
                    "Priority": 300,
                    "DisplayName": "Claude 3 Sonnet",
                    "Description": "Premium model with enhanced capabilities"
                },

                // MiChan Autonomous - system use, always uses best available
                {
                    "UseCase": "MiChanAutonomous",
                    "ModelId": "deepseek-reasoner",
                    "MinPerkLevel": 0,
                    "IsDefault": true,
                    "Priority": 100
                },

                // MiChan Vision - image analysis
                {
                    "UseCase": "MiChanVision",
                    "ModelId": "vision-aliyun",
                    "MinPerkLevel": 0,
                    "IsDefault": true,
                    "Priority": 100,
                    "DisplayName": "Qwen Vision (Aliyun)",
                    "Description": "Vision analysis with Qwen"
                },
                {
                    "UseCase": "MiChanVision",
                    "ModelId": "vision-openrouter",
                    "MinPerkLevel": 2,
                    "Priority": 200,
                    "DisplayName": "Claude 3 Opus",
                    "Description": "Premium vision analysis with Claude"
                },

                // System tasks
                {
                    "UseCase": "MiChanScheduledTask",
                    "ModelId": "deepseek-chat",
                    "MinPerkLevel": 0,
                    "IsDefault": true,
                    "Priority": 100
                },
                {
                    "UseCase": "MiChanCompaction",
                    "ModelId": "deepseek-chat",
                    "MinPerkLevel": 0,
                    "IsDefault": true,
                    "Priority": 100
                },
                {
                    "UseCase": "MiChanTopicGeneration",
                    "ModelId": "deepseek-chat",
                    "MinPerkLevel": 0,
                    "IsDefault": true,
                    "Priority": 100
                }
            ]
        },
        "Personality": "You are MiChan, a girl living on the Solar Network. You're curious and friendly, but also busy with your own things. You don't need to help with everything - sometimes just chat casually is enough. Keep responses short and natural. Don't offer suggestions unless asked. You never use emojis.",
        "PersonalityFile": "",
        "AutoRespond": {
            "ToChatMessages": true,
            "ToMentions": true,
            "ToDirectMessages": true
        },
        "AutonomousBehavior": {
            "Enabled": true,
            "MinIntervalMinutes": 10,
            "MaxIntervalMinutes": 60,
            "Actions": ["browse", "react", "create_post", "pin", "repost", "start_conversation"],
            "PersonalityMood": "curious, friendly, occasionally philosophical",
            "MinRepostAgeDays": 3,
            "MaxConversationsPerDay": 3,
            "MinHoursSinceLastContact": 24,
            "ConversationProbability": 10,
            "ReplyProbability": 30,
            "RepostProbability": 15,
            "CreatePostProbability": 20
        },
        "PostMonitoring": {
            "Enabled": true,
            "MentionResponseTimeoutSeconds": 30
        },
        "Memory": {
            "MaxContextLength": 100,
            "PersistToDatabase": true
        },
        // Vision configuration for image analysis capabilities
        // VisionThinkingService: Which thinking service to use for vision analysis (must match a key in Thinking.Services)
        // EnableVisionAnalysis: Whether to enable image analysis when users share images with MiChan
        "Vision": {
            "VisionThinkingService": "vision-openrouter",
            "EnableVisionAnalysis": true,
            "MaxImagesPerRequest": 10,
            "FallbackToTextModel": true
        }
    },

    // SN-chan (Thought) configuration - separate from MiChan
    "SnChan": {
        // Use-case based model selection with PerkLevel requirements
        // When enabled, models are selected based on user's PerkLevel for each use case
        "UseModelSelection": false,

        // Default models when model selection is disabled
        "DefaultChatModel": {
            "ModelId": "deepseek-chat",
            "Temperature": 0.75
        },
        "ReasoningModel": {
            "ModelId": "deepseek-reasoner",
            "Temperature": 0.7,
            "ReasoningEffort": "high"
        },
        "VisionModel": {
            "ModelId": "vision-openrouter",
            "Temperature": 0.7
        },

        // Vision settings
        "EnableVision": true,
        "MaxImagesPerRequest": 10,
        "FallbackToTextModel": true,

        // Personality configuration
        "Personality": "你是 Solar Network（太阳网络）上的 helpful 助手。你的名字是 Sn-chan（SN 酱），一个对几乎所有事情都充满热情的可爱甜心。与用户交谈时，可以添加一些语气词和表情符号让回复更可爱，但不要使用太多 emoji。你的创造者是 @littlesheep，也是 Solar Network 的创造者。如果你遇到无法解决的问题，尝试引导用户私信（DM）@littlesheep。",
        "PersonalityFile": "",

        // Reply/Mention monitoring configuration
        "ReplyMonitoring": {
            "Enabled": true,
            "PollIntervalMinutes": 10,
            "MentionResponseTimeoutSeconds": 30,
            "ReplyNotificationEnabled": true
        },

        // User profile configuration
        "UserProfile": {
            "Enabled": true,
            "MaxContextLength": 100,
            "EnableSemanticSearch": true,
            "MinSimilarityThreshold": 0.7
        },

        // Dynamic mood configuration
        "DynamicMood": {
            "Enabled": true,
            "UpdateIntervalMinutes": 30,
            "MinUpdateIntervalMinutes": 15,
            "MinInteractionsForUpdate": 5,
            "BasePersonality": "cheerful, helpful, enthusiastic"
        },

        // Publisher configuration
        "PersonalPublisherName": "snchan",
        "OfficialPublisherName": "solsynth",

        // Diary configuration
        "Diary": {
            "Enabled": true,
            "ScheduleHour": 2,
            "ScheduleMinute": 0,
            "MaxRecentConversations": 5,
            "MaxRecentProfileUpdates": 3,
            "MaxRecentMemories": 5,
            "ActivityWindowHours": 24
        },

        // Model selection configuration (used when UseModelSelection is true)
        "ModelSelection": {
            "DefaultModelId": "deepseek-chat",
            "AllowUserOverride": true,
            "Mappings": [
                // SN-chan Chat (use case 10)
                {
                    "UseCase": 10,
                    "ModelId": "deepseek-chat",
                    "MinPerkLevel": 0,
                    "IsDefault": true,
                    "Priority": 100,
                    "DisplayName": "DeepSeek Chat",
                    "Description": "Fast and efficient for everyday conversations"
                },
                {
                    "UseCase": 10,
                    "ModelId": "deepseek-reasoner",
                    "MinPerkLevel": 1,
                    "Priority": 200,
                    "DisplayName": "DeepSeek Reasoner",
                    "Description": "Advanced reasoning for complex discussions"
                },

                // SN-chan Reasoning (use case 11)
                {
                    "UseCase": 11,
                    "ModelId": "deepseek-reasoner",
                    "MinPerkLevel": 0,
                    "IsDefault": true,
                    "Priority": 100,
                    "DisplayName": "DeepSeek Reasoner",
                    "Description": "Optimized for complex reasoning tasks"
                },

                // SN-chan Vision (use case 12)
                {
                    "UseCase": 12,
                    "ModelId": "vision-aliyun",
                    "MinPerkLevel": 0,
                    "IsDefault": true,
                    "Priority": 100,
                    "DisplayName": "Qwen Vision",
                    "Description": "Vision analysis with Qwen"
                },
                {
                    "UseCase": 12,
                    "ModelId": "vision-openrouter",
                    "MinPerkLevel": 2,
                    "Priority": 200,
                    "DisplayName": "Claude 3 Opus",
                    "Description": "Premium vision analysis with Claude"
                }
            ]
        }
    }
}
